modules = ["php-8.2", "nodejs-20", "web", "php-8.4", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Laravel Development Server"

[[workflows.workflow]]
name = "Laravel Development Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run start"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5002
externalPort = 3001

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 8099
externalPort = 8099

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "php -S 0.0.0.0:${PORT:-5000} public/router.php"]
build = ["bash", "build.sh"]
publicDir = "public"

[userenv]

